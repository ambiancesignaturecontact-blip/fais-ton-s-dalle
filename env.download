# ===========================================================
# FAIS TON S'DALLE — Variables d'environnement
# Copier ce fichier vers .env et remplir les valeurs
# ===========================================================

# --- Base de données PostgreSQL (Vercel Postgres / Supabase) ---
POSTGRES_URL="postgres://user:password@host:5432/dbname"
POSTGRES_PRISMA_URL="postgres://user:password@host:5432/dbname?schema=public"
POSTGRES_URL_NON_POOLING="postgres://user:password@host:5432/dbname"
POSTGRES_USER="user"
POSTGRES_HOST="host"
POSTGRES_PASSWORD="password"
POSTGRES_DATABASE="dbname"

# --- Domaine / URL du site ---
SITE_URL="https://faistonsdalle.fr"
NEXT_PUBLIC_SITE_URL="https://faistonsdalle.fr"

# --- Uber Eats (API Store) ---
UBER_STORE_ID="qQkk53_5XNaUCkcZTskV6g"
UBER_STORE_URL="https://www.ubereats.com/fr-en/store/fais-ton-sdalle/qQkk53_5XNaUCkcZTskV6g"

# --- WhatsApp Business ---
WHATSAPP_NUMBER="33672044875"
WHATSAPP_MESSAGE="Bonjour ! Je souhaite commander."

# --- Newsletter (Mailchimp / Resend / SendGrid) ---
# Pour envoyer les emails de la newsletter
MAILCHIMP_API_KEY=""
MAILCHIMP_LIST_ID=""
# OU
RESEND_API_KEY=""
NEWSLETTER_FROM="contact@faistonsdalle.com"

# --- Google Analytics 4 ---
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# --- Google Maps (pour embeds optionnels) ---
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# --- TikTok (Pixel / API) ---
TIKTOK_PIXEL_ID=""

# --- Admin (connexion dashboard) ---
ADMIN_EMAIL="contact@faistonsdalle.com"
ADMIN_PASSWORD_HASH=""  # généré avec bcrypt

# --- Fidélité (points) ---
LOYALTY_POINTS_PER_SANDWICH=1
LOYALTY_FREE_AFTER=10  # 10 sandwichs = 1 gratuit

# --- Contact ---
CONTACT_EMAIL="contact@faistonsdalle.com"
CONTACT_PHONE="06 72 04 48 75"

# --- Stripe (Paiement en ligne) ---
# Crée un compte Stripe : https://dashboard.stripe.com/register
# Clés disponibles dans : Dashboard → Developers → API Keys
STRIPE_SECRET_KEY="sk_live_xxxxxxxxxxxxx"  # 🔒 NE JAMAIS PARTAGER
NEXT_PUBLIC_STRIPE_KEY="pk_live_xxxxxxxxxxxxx"  # Clé publiable (sûre côté client)

# --- Mode développement / production ---
NODE_ENV="production"
