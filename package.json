fi p,.fi a{font-size:.66rem;color:rgba(255,255,255,.45);display:block;margin-bottom:4px}.fi a:hover{color:var(--s)}.fb{max-width:1100px;margin:14px auto 0;padding-top:12px;border-top:1px solid rgba(255,255,255,.06);text-align:center;font-size:.6rem}@media(max-width:1024px){.grid{grid-template-columns:repeat(auto-fill,minmax(210px,1fr))}}@media(max-width:768px){.nv a:not(.ct):not(.tg){display:none}.grid{grid-template-columns:1fr;max-width:420px}.cp{width:100vw;right:-100vw}.tabs button{padding:7px 16px}.hd{height:50px;padding:0 12px}.lg img{height:26px}.br{font-size:.78rem}.crd-img{height:170px}.hero{padding:36px 14px 32px}}@media(max-width:480px){.crd-img{height:150px}.crd-body{min-height:75px;padding:12px 14px 14px}.hero h1{font-size:clamp(1.2rem,7vw,1.5rem)}}</style>
<script>
